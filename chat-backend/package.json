{
  "name": "chat-backend",
  "version": "1.0.0",
  "description": "Chat backend with PostgreSQL and Redis",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun dist/index.js",
    "check": "bunx --bun @biomejs/biome check --write",
    "format": "bunx --bun @biomejs/biome format",
    "lint": "bunx --bun @biomejs/biome lint",
    "seed": "bun seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "typescript": "^5.3.3"
  }
}
